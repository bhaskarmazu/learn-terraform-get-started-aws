# Local .terraform directories
**/.terraform/*

# .tfstate files (contain secrets/sensitive data)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable files that may contain secrets
*.tfvars
*.tfvars.json

# CLI config files with credentials
.terraformrc
terraform.rc

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Lock file (optional many teams DO commit this one)
# .terraform.lock.hcl